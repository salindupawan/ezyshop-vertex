                    <padding>
                        <Insets bottom="20.0" left="30.0" right="30.0" top="5.0" />
                    </padding>
                    <children>

                        <Label text="Employment Information" textFill="WHITE">
                            <font>
                                <Font name="System Bold" size="18.0" />
                            </font>
                        </Label>

                        <GridPane hgap="40.0">
                            <columnConstraints>
                                <ColumnConstraints hgrow="SOMETIMES" percentWidth="33.33" />
                                <ColumnConstraints hgrow="SOMETIMES" percentWidth="33.33" />
                                <ColumnConstraints hgrow="SOMETIMES" percentWidth="33.33" />
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints minHeight="10.0" prefHeight="90.0" vgrow="SOMETIMES" />
                            </rowConstraints>
                            <children>
                                <VBox spacing="8.0" GridPane.columnIndex="0">
                                    <children>
                                        <Label text="Employment Start Date" textFill="WHITE"><font><Font size="15.0" /></font></Label>
                                        <DatePicker fx:id="dpStartDate" maxWidth="Infinity" minHeight="48.0" prefHeight="50.0" style="-fx-background-radius: 0; -fx-font-size: 15px;" />
                                    </children>
                                </VBox>
                                <VBox spacing="8.0" GridPane.columnIndex="1">
                                    <children>
                                        <Label text="Contract Duration (Months)" textFill="WHITE"><font><Font size="15.0" /></font></Label>
                                        <ComboBox fx:id="cmbDuration" maxWidth="Infinity" minHeight="48.0" prefHeight="50.0" style="-fx-background-radius: 0; -fx-background-color: #ffffff; -fx-font-size: 15px;" />
                                    </children>
                                </VBox>
                            </children>
                        </GridPane>

                        <Pane maxHeight="1.0" minHeight="1.0" prefHeight="1.0" style="-fx-border-color: white; -fx-border-style: dashed; -fx-border-width: 1 0 0 0;" VBox.vgrow="NEVER">
                            <VBox.margin>
                                <Insets />
                            </VBox.margin>

        <VBox spacing="25.0" style="-fx-background-color: #00364d;" VBox.vgrow="NEVER">
            <padding>
                <Insets bottom="20.0" left="30.0" right="30.0" top="25.0" />
            </padding>
            <children>
                <GridPane hgap="40.0" vgap="20.0">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" percentWidth="33.33" />
                        <ColumnConstraints hgrow="SOMETIMES" percentWidth="33.33" />
                        <ColumnConstraints hgrow="SOMETIMES" percentWidth="33.33" />
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints minHeight="10.0" prefHeight="85.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="85.0" vgrow="SOMETIMES" />
                    </rowConstraints>
                    <children>
                        <VBox spacing="8.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <children>
                                <HBox spacing="4.0">
                                    <children>
                                        <Label text="First Name" textFill="WHITE"><font><Font size="15.0" /></font></Label>
                                        <Label text="*" textFill="#ff4d4d"><font><Font name="System Bold" size="15.0" /></font></Label>
                                    </children>
                                </HBox>
                                <TextField fx:id="txtFirstName" minHeight="48.0" prefHeight="50.0" style="-fx-background-radius: 0; -fx-font-size: 16px;" />
                            </children>
                        </VBox>
                        <VBox spacing="8.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <children>
                                <HBox spacing="4.0">
                                    <children>
                                        <Label text="Last Name" textFill="WHITE"><font><Font size="15.0" /></font></Label>
                                        <Label text="*" textFill="#ff4d4d"><font><Font name="System Bold" size="15.0" /></font></Label>
                                    </children>
                                </HBox>
                                <TextField fx:id="txtLastName" minHeight="48.0" prefHeight="50.0" style="-fx-background-radius: 0; -fx-font-size: 16px;" />
                            </children>
                        </VBox>
                        <VBox spacing="8.0" GridPane.columnIndex="2" GridPane.rowIndex="0">
                            <children>
                                <HBox spacing="4.0">
                                    <children>
                                        <Label text="Username" textFill="WHITE"><font><Font size="15.0" /></font></Label>
                                        <Label text="*" textFill="#ff4d4d"><font><Font name="System Bold" size="15.0" /></font></Label>
                                    </children>
                                </HBox>
                                <TextField fx:id="txtUsername" minHeight="48.0" prefHeight="50.0" style="-fx-background-radius: 0; -fx-font-size: 16px;" />
                            </children>
                        </VBox>
                        <VBox spacing="8.0" GridPane.columnIndex="0" GridPane.rowIndex="1">
                            <children>
                                <Label text="Email (Optional)" textFill="WHITE"><font><Font size="15.0" /></font></Label>
                                <TextField fx:id="txtEmail" minHeight="48.0" prefHeight="50.0" style="-fx-background-radius: 0; -fx-font-size: 16px;" />
                            </children>
                        </VBox>
                        <VBox spacing="8.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
                            <children>
                                <HBox spacing="4.0">

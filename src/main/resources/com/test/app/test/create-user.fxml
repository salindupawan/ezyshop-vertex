                                        <Label text="*" textFill="#ff4d4d"><font><Font name="System Bold" size="15.0" /></font></Label>
                                    </children>
                                </HBox>
                                <TextField fx:id="txtPhoneNumber" minHeight="48.0" prefHeight="50.0" style="-fx-background-radius: 0; -fx-font-size: 16px;" />
                            </children>
                        </VBox>
                        <VBox spacing="8.0" GridPane.columnIndex="2" GridPane.rowIndex="1">
                            <children>
                                <Label text="User ID (Auto/Manual)" textFill="WHITE"><font><Font size="15.0" /></font></Label>
                                <TextField fx:id="txtUserId" editable="false" minHeight="48.0" prefHeight="50.0" style="-fx-background-color: #b0b0b0; -fx-background-radius: 0; -fx-font-size: 16px; -fx-font-weight: bold;" />
                            </children>
                        </VBox>
                    </children>
                </GridPane>
                <Pane maxHeight="1.0" minHeight="1.0" prefHeight="1.0" style="-fx-border-color: white; -fx-border-style: dashed; -fx-border-width: 1 0 0 0;" VBox.vgrow="NEVER">
                    <VBox.margin>
                        <Insets />
                    </VBox.margin>
                </Pane>
            </children>
        </VBox>

        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" prefHeight="375.0" prefWidth="1360.0" style="-fx-background: #00364d; -fx-background-color: #00364d; -fx-border-color: #00364d;" vbarPolicy="AS_NEEDED" VBox.vgrow="ALWAYS">

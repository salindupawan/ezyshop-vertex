                                                <Label text="Confirm Password" textFill="WHITE"><font><Font size="15.0" /></font></Label>
                                                <Label text="*" textFill="#ff4d4d"><font><Font name="System Bold" size="15.0" /></font></Label>
                                            </children>
                                        </HBox>
                                        <PasswordField fx:id="txtConfirmPassword" minHeight="48.0" prefHeight="50.0" style="-fx-background-radius: 0; -fx-font-size: 16px;" />
                                    </children>
                                </VBox>

                                <VBox spacing="8.0" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                    <children>
                                        <Label text="Max Login Attempts (Default 3)" textFill="WHITE"><font><Font size="15.0" /></font></Label>
                                        <TextField fx:id="txtMaxAttempts" minHeight="48.0" prefHeight="50.0" style="-fx-background-radius: 0; -fx-font-size: 16px;" />
                                    </children>
                                </VBox>
                                <VBox spacing="8.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                    <children>
                                        <Label text="Lockout Duration" textFill="WHITE"><font><Font size="15.0" /></font></Label>
                                        <TextField fx:id="txtLockoutDuration" minHeight="48.0" prefHeight="50.0" style="-fx-background-radius: 0; -fx-font-size: 16px;" />
                                    </children>
                                </VBox>

                                <VBox spacing="8.0" GridPane.columnIndex="0" GridPane.rowIndex="2">
                                    <children>
                                        <HBox spacing="4.0">
                                            <children>
                                                <Label text="Role" textFill="WHITE"><font><Font size="15.0" /></font></Label>
                                                <Label text="*" textFill="#ff4d4d"><font><Font name="System Bold" size="15.0" /></font></Label>
                                            </children>
                                        </HBox>
                                        <HBox alignment="CENTER_LEFT" spacing="0.0">
                                            <children>
                                                <ComboBox fx:id="cmbRole" maxWidth="Infinity" minHeight="48.0" prefHeight="50.0" style="-fx-background-radius: 0; -fx-background-color: #ffffff; -fx-font-size: 15px;" HBox.hgrow="ALWAYS" />
                                                <Button fx:id="btnNewRole" minHeight="48.0" minWidth="50.0" mnemonicParsing="false" prefHeight="50.0" prefWidth="50.0" style="-fx-background-color: #00bfff; -fx-background-radius: 0;" text="+" textFill="WHITE"><font><Font name="System Bold" size="20.0" /></font></Button>
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                                <VBox spacing="8.0" GridPane.columnIndex="1" GridPane.rowIndex="2">
                                    <children>
                                        <HBox spacing="4.0">
                                            <children>
                                                <Label text="Status" textFill="WHITE"><font><Font size="15.0" /></font></Label>
                                                <Label text="*" textFill="#ff4d4d"><font><Font name="System Bold" size="15.0" /></font></Label>
                                            </children>
                                        </HBox>
                                        <ComboBox fx:id="cmbStatus" maxWidth="Infinity" minHeight="48.0" prefHeight="50.0" style="-fx-background-radius: 0; -fx-background-color: #ffffff; -fx-font-size: 15px;" />
                                    </children>
                                </VBox>
                            </children>
                        </GridPane>
                    </children>
                </VBox>
            </content>
        </ScrollPane>

        <HBox alignment="CENTER_RIGHT" spacing="25.0" style="-fx-background-color: #00364d;" VBox.vgrow="NEVER">
            <children>
                <Button fx:id="btnCancel" minHeight="50.0" mnemonicParsing="false" onAction="#openManageUserWindow" prefHeight="55.0" prefWidth="220.0" style="-fx-background-color: #ffffff; -fx-background-radius: 0;" text="Cancel" textFill="#00364d"><font><Font name="System Bold" size="16.0" /></font></Button>
                <Button fx:id="btnSave" minHeight="50.0" mnemonicParsing="false" prefHeight="55.0" prefWidth="220.0" style="-fx-background-color: #00bfff; -fx-background-radius: 0;" text="Save" textFill="WHITE"><font><Font name="System Bold" size="16.0" /></font></Button>
            </children>
            <padding>
                <Insets bottom="25.0" right="30.0" top="15.0" />
            </padding>
        </HBox>

        <HBox alignment="CENTER_LEFT" minHeight="40.0" prefHeight="45.0" style="-fx-background-color: #e0f2f1;" VBox.vgrow="NEVER">
            <children>
                <Label fx:id="lblTerminal" text="Terminal: 01 (Auto)"><font><Font size="13.0" /></font><padding><Insets left="20.0" right="20.0" /></padding></Label>
                <Line endY="25.0" stroke="#999999" />
                <Label text="Database:"><font><Font size="13.0" /></font><padding><Insets left="20.0" /></padding></Label>
                <Label fx:id="lblDatabase" text="Connected" textFill="#00796b"><font><Font name="System Bold" size="13.0" /></font><padding><Insets left="5.0" right="20.0" /></padding></Label>
                <Line endY="25.0" stroke="#999999" />
                <Label text="Mode:"><font><Font size="13.0" /></font><padding><Insets left="20.0" right="5.0" /></padding></Label>
                <Label fx:id="lblMode" text="Offline"><font><Font size="13.0" /></font><padding><Insets right="20.0" /></padding></Label>
                <Line endY="25.0" stroke="#999999" />
                <Label text="System Status:"><font><Font size="13.0" /></font><padding><Insets left="20.0" right="5.0" /></padding></Label>
                <Label fx:id="lblSystemStatus" text="Ready" textFill="#00796b"><font><Font name="System Bold" size="13.0" /></font><padding><Insets right="20.0" /></padding></Label>
                <Pane HBox.hgrow="ALWAYS" />
                <Label fx:id="lblCopyright" text="EZYSHOP @ 2026"><font><Font size="13.0" /></font><padding><Insets right="20.0" /></padding></Label>
            </children>
        </HBox>
    </children>
</VBox>

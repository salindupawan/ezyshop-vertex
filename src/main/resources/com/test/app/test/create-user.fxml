        <HBox alignment="CENTER_LEFT" style="-fx-background-color: #00364d;" VBox.vgrow="NEVER">
            <children>
                <Label text="ADD NEW USER INFORMATIONS" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="22.0" />
                    </font>
                    <padding>
                        <Insets bottom="15.0" top="15.0" />
                    </padding>
                </Label>
            </children>
            <padding>
                <Insets left="30.0" right="30.0" />
            </padding>
        </HBox>

        <Pane maxHeight="1.0" minHeight="1.0" prefHeight="1.0" style="-fx-border-color: white; -fx-border-style: dashed; -fx-border-width: 1 0 0 0;" VBox.vgrow="NEVER">
            <VBox.margin>

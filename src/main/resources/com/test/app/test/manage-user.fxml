        <HBox alignment="CENTER_LEFT" minHeight="65.0" prefHeight="75.0" style="-fx-background-color: #002b3d;">
            <children>
                <Label fx:id="lblHeaderTitle" text="MANAGE USERS" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="22.0" />
                    </font>
                </Label>
                <Pane HBox.hgrow="ALWAYS" />
                <HBox alignment="CENTER" spacing="10.0">
                    <children>
                        <Label text="Total Users:" textFill="#00bfff">
                            <font>
                                <Font size="15.0" />
                            </font>
                        </Label>
                        <Label fx:id="lblTotalUsers" text="12" textFill="WHITE">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                        </Label>
                    </children>
                    <HBox.margin>
                        <Insets right="40.0" />
                    </HBox.margin>
                </HBox>
                <HBox alignment="CENTER" spacing="10.0">
                    <children>
                        <Label text="Active Users:" textFill="#00bfff">
                            <font>
                                <Font size="15.0" />
                            </font>
                        </Label>
                        <Label fx:id="lblActiveUsers" text="10" textFill="WHITE">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                        </Label>
                    </children>
                    <HBox.margin>
                        <Insets right="40.0" />
                    </HBox.margin>
                </HBox>
                <HBox alignment="CENTER" spacing="10.0">
                    <children>
                        <Label text="Inactive Users:" textFill="#00bfff">
                            <font>
                                <Font size="15.0" />
                            </font>
                        </Label>
                        <Label fx:id="lblInactiveUsers" text="02" textFill="WHITE">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                        </Label>
                    </children>
                </HBox>
            </children>
            <padding>
                <Insets left="30.0" right="30.0" />
            </padding>
        </HBox>

        <Pane maxHeight="1.0" minHeight="1.0" prefHeight="1.0" style="-fx-border-color: white; -fx-border-style: dashed; -fx-border-width: 1 0 0 0;" VBox.vgrow="NEVER">
            <VBox.margin>
                <Insets left="30" right="30" />
            </VBox.margin>
        </Pane>

        <HBox alignment="CENTER_LEFT" spacing="15.0">
            <children>
                <TextField fx:id="txtSearch" minHeight="45.0" prefHeight="48.0" prefWidth="450.0" promptText="Search users..." style="-fx-background-color: #ffffff; -fx-background-radius: 0; -fx-font-size: 15px;" />
                <Pane HBox.hgrow="ALWAYS" />
                <Button fx:id="btnSearchAction" minHeight="45.0" minWidth="45.0" mnemonicParsing="false" prefHeight="48.0" prefWidth="48.0" style="-fx-background-color: #00bfff; -fx-background-radius: 0;" />
                <Button fx:id="btnClear" minHeight="45.0" mnemonicParsing="false" prefHeight="48.0" prefWidth="180.0" style="-fx-background-color: #00bfff; -fx-background-radius: 0;" text="Clear" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="16.0" />
                    </font>
                </Button>
            </children>
            <padding>
                <Insets bottom="20.0" left="30.0" right="30.0" top="20.0" />
            </padding>
        </HBox>

        <TableView fx:id="tblUsers" minHeight="350.0" prefHeight="400.0" prefWidth="1300.0" stylesheets="@styles.css" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId" minWidth="70.0" prefWidth="80.0" text="ID" />
                <TableColumn fx:id="colName" minWidth="150.0" prefWidth="180.0" text="Name" />
                <TableColumn fx:id="colRole" minWidth="110.0" prefWidth="130.0" text="Role" />
                <TableColumn fx:id="colStatus" minWidth="110.0" prefWidth="130.0" text="Status" />
                <TableColumn fx:id="colCreatedBy" minWidth="130.0" prefWidth="150.0" text="Created By" />
                <TableColumn fx:id="colCreatedAt" minWidth="140.0" prefWidth="160.0" text="Created At" />
                <TableColumn fx:id="colModifiedBy" minWidth="130.0" prefWidth="150.0" text="Modified By" />
                <TableColumn fx:id="colModifiedAt" minWidth="140.0" prefWidth="160.0" text="Modified At" />
                <TableColumn fx:id="colAction" minWidth="80.0" prefWidth="90.0" text="Action" />
            </columns>
            <VBox.margin>
                <Insets left="30.0" right="30.0" />
            </VBox.margin>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>

        <Pane maxHeight="1.0" minHeight="1.0" prefHeight="1.0" style="-fx-border-color: white; -fx-border-style: dashed; -fx-border-width: 1 0 0 0;" VBox.vgrow="NEVER">
            <VBox.margin>
                <Insets left="30" top="20" bottom="20" right="30" />
            </VBox.margin>
        </Pane>

        <HBox alignment="CENTER" spacing="20.0" VBox.vgrow="NEVER">
            <children>
                <Button fx:id="createUser" contentDisplay="TOP" minHeight="75.0" minWidth="140.0" mnemonicParsing="false" onAction="#openAddUserWindow" prefHeight="85.0" prefWidth="180.0" style="-fx-background-color: #ffffff; -fx-background-radius: 0; -fx-text-alignment: center;" text="Add User&#10;[F1]">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                </Button>
                <Button fx:id="btnEditUser" contentDisplay="TOP" minHeight="75.0" minWidth="140.0" mnemonicParsing="false" prefHeight="85.0" prefWidth="180.0" style="-fx-background-color: #ffffff; -fx-background-radius: 0; -fx-text-alignment: center;" text="Edit User&#10;[F2]">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                </Button>
                <Button fx:id="btnResetPassword" contentDisplay="TOP" minHeight="75.0" minWidth="140.0" mnemonicParsing="false" prefHeight="85.0" prefWidth="180.0" style="-fx-background-color: #ffffff; -fx-background-radius: 0; -fx-text-alignment: center;" text="Reset Password&#10;[F4]">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                </Button>
                <Button fx:id="btnRefresh" contentDisplay="TOP" minHeight="75.0" minWidth="140.0" mnemonicParsing="false" prefHeight="85.0" prefWidth="180.0" style="-fx-background-color: #ffffff; -fx-background-radius: 0; -fx-text-alignment: center;" text="Refresh&#10;[F5]">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                </Button>
                <Button fx:id="btnManageRoles" contentDisplay="TOP" minHeight="75.0" minWidth="140.0" mnemonicParsing="false" prefHeight="85.0" prefWidth="180.0" style="-fx-background-color: #ffffff; -fx-background-radius: 0; -fx-text-alignment: center;" text="Manage Roles&#10;[F6]">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                </Button>
                <Button fx:id="btnBack" contentDisplay="TOP" minHeight="75.0" minWidth="140.0" mnemonicParsing="false" prefHeight="85.0" prefWidth="180.0" style="-fx-background-color: #ffffff; -fx-background-radius: 0; -fx-text-alignment: center;" text="Back&#10;[ESC]">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                </Button>
            </children>
            <padding>
                <Insets bottom="25.0" />
            </padding>
        </HBox>

        <HBox alignment="CENTER_LEFT" minHeight="40.0" prefHeight="45.0" style="-fx-background-color: #e0f2f1;">
            <children>
                <Label fx:id="lblTerminal" text="Terminal: 01 (Auto)">
                    <font>
                        <Font size="13.0" />
                    </font>
                    <padding>
                        <Insets left="20.0" right="20.0" />
                    </padding>
                </Label>
                <Line endY="25.0" stroke="#999999" />
                <Label text="Database:">
                    <font>
                        <Font size="13.0" />
                    </font>
                    <padding>
                        <Insets left="20.0" />
                    </padding>
                </Label>
                <Label fx:id="lblDatabase" text="Connected" textFill="#00796b">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                    <padding>
                        <Insets left="5.0" right="20.0" />
                    </padding>
                </Label>
                <Line endY="25.0" stroke="#999999" />
                <Label text="Mode:">
                    <font>
                        <Font size="13.0" />
                    </font>
                    <padding>
                        <Insets left="20.0" right="5.0" />
                    </padding>
                </Label>
                <Label fx:id="lblMode" text="Offline">
                    <font>
                        <Font size="13.0" />
                    </font>
                    <padding>
                        <Insets right="20.0" />
                    </padding>
                </Label>
                <Line endY="25.0" stroke="#999999" />
                <Label text="System Status:">
                    <font>
                        <Font size="13.0" />
                    </font>
                    <padding>
                        <Insets left="20.0" right="5.0" />
                    </padding>
                </Label>
                <Label fx:id="lblSystemStatus" text="Ready" textFill="#00796b">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                    <padding>
                        <Insets right="20.0" />
                    </padding>
                </Label>
                <Pane HBox.hgrow="ALWAYS" />
                <Label fx:id="lblCopyright" text="EZYSHOP @ 2026">
                    <font>
                        <Font size="13.0" />
                    </font>
                    <padding>
                        <Insets right="20.0" />
                    </padding>
                </Label>
            </children>
        </HBox>
    </children>
</VBox>
